    "@nestjs/platform-fastify": "^11.1.28",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "viem": "^2.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.23.1",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4",
    "@paymaster/sdk": "*"
  }
}
