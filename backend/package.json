{
  "name": "@paymaster/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sponsorship backend: signature engine, policy engine, chain adapters, and APIs.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
