# Compiler files
cache/
out/

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# Docs
docs/

# Dotenv file
.env
.env.*
!.env.example

# Secrets. The sponsorship signer key must never reach the repo; in production it lives in a
# KMS/HSM and the backend holds only a reference to it.
*.pem
*.key
keystore/

# Node (backend + SDK land here in later slices)
node_modules/
dist/
coverage/
lcov.info

# Bundler binary: a 56MB per-platform release artifact, fetched by `npm run bundler:fetch`
# with a pinned version and checksum.
backend/.bundler/

# Generated by deploy/local-setup.sh — contains keys (dev, but do not commit)
deploy/.env.local

# Foundry script broadcast logs
contracts/broadcast/
